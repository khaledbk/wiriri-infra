# cdn / imgproxy secrets — real values live in Infisical (3 stages), NEVER committed.
# Place a real .env next to storage-01 docker-compose for imgproxy to read.

# imgproxy URL signing (HMAC)
#   openssl rand -hex 32   -> IMGPROXY_KEY
#   openssl rand -hex 16   -> IMGPROXY_SALT
IMGPROXY_KEY=
IMGPROXY_SALT=

# imgproxy -> MinIO: a DEDICATED READ-ONLY user on wiriri-prod-images only
# (create with mc: policy = s3:GetObject + s3:ListBucket on wiriri-prod-images).
# Do NOT reuse the backend rw user or root.
IMGPROXY_S3_ACCESS_KEY=wiriri_imgproxy_ro
IMGPROXY_S3_SECRET_KEY=
